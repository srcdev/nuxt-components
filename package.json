{
  "name": "srcdev-nuxt-components",
  "type": "module",
  "version": "9.1.55",
  "main": "nuxt.config.ts",
  "types": "types.d.ts",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf .nuxt && rm -rf .output",
    "cleanall": "rm -rf node_modules && rm -rf .nuxt && rm -rf .output && rm package-lock.json",
    "reinstall": "rm -rf node_modules && npm install",
    "cleaninstall": "npm run clean && npm run reinstall",
    "generate:ramps": "node scripts/generate-ramps.mjs",
    "check:ramps": "node scripts/check-ramps.mjs",
    "dev": "npm run generate:ramps && SRCDEV_STANDALONE=true nuxt dev",
    "build": "npm run generate:ramps && SRCDEV_STANDALONE=true nuxt build",
    "generate": "npm run generate:ramps && SRCDEV_STANDALONE=true nuxt generate",
    "preview": "SRCDEV_STANDALONE=true nuxt preview",
    "lint": "eslint .",
    "prepare": "SRCDEV_STANDALONE=true nuxt prepare",
    "release": "release-it",
    "test": "SRCDEV_STANDALONE=true vitest",
    "test:run": "SRCDEV_STANDALONE=true vitest --run",
    "test:ui": "SRCDEV_STANDALONE=true vitest --ui",
    "test:update": "SRCDEV_STANDALONE=true vitest --update",
    "storybook": "SRCDEV_STANDALONE=true storybook dev -p 6006",
    "storybook:build": "SRCDEV_STANDALONE=true storybook build",
    "storybook:serve": "npm run storybook:build && npx http-server storybook-static --port 6006",
    "storybook:cache:clean": "rm -rf node_modules/.cache/storybook node_modules/.vite",
    "playwright": "SRCDEV_STANDALONE=true npx playwright test",
    "playwright:update": "SRCDEV_STANDALONE=true npx playwright test --update-snapshots"
  },
  "files": [
    ".claude/",
    "app/",
    "modules/",
    "nuxt.config.ts",
    "types.d.ts"
  ],
  "peerDependencies": {
    "@iconify-json/akar-icons": "*",
    "@iconify-json/bi": "*",
    "@iconify-json/bitcoin-icons": "*",
    "@iconify-json/gravity-ui": "*",
    "@iconify-json/ic": "*",
    "@iconify-json/logos": "*",
    "@iconify-json/lucide": "*",
    "@iconify-json/material-symbols": "*",
    "@iconify-json/mdi": "*",
    "@iconify-json/radix-icons": "*"
  },
  "peerDependenciesMeta": {
    "@iconify-json/akar-icons": {
      "optional": true
    },
    "@iconify-json/bi": {
      "optional": true
    },
    "@iconify-json/bitcoin-icons": {
      "optional": true
    },
    "@iconify-json/gravity-ui": {
      "optional": true
    },
    "@iconify-json/ic": {
      "optional": true
    },
    "@iconify-json/logos": {
      "optional": true
    },
    "@iconify-json/lucide": {
      "optional": true
    },
    "@iconify-json/material-symbols": {
      "optional": true
    },
    "@iconify-json/mdi": {
      "optional": true
    },
    "@iconify-json/radix-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "4.1.2",
    "@iconify-json/akar-icons": "1.2.7",
    "@iconify-json/bi": "1.2.7",
    "@iconify-json/bitcoin-icons": "1.2.5",
    "@iconify-json/gravity-ui": "1.2.12",
    "@iconify-json/ic": "*",
    "@iconify-json/logos": "1.2.11",
    "@iconify-json/lucide": "*",
    "@iconify-json/material-symbols": "1.2.73",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/radix-icons": "*",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/schema": "4.4.6",
    "@nuxt/test-utils": "3.23.0",
    "@nuxtjs/storybook": "9.1.0-29374011.dab79ae",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.0.7",
    "@storybook/addon-docs": "10.0.7",
    "@storybook/builder-vite": "10.0.7",
    "@vue/test-utils": "2.4.10",
    "@vueuse/core": "14.3.0",
    "eslint": "10.4.0",
    "eslint-plugin-storybook": "10.0.7",
    "happy-dom": "20.9.0",
    "nuxt-qrcode": "0.4.10",
    "patch-package": "8.0.1",
