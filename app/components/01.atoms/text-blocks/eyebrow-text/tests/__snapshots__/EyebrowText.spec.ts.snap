// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`EyebrowText > renders correct HTML structure for each fontSize variant 1`] = `"<div class="eyebrow-text large">Snapshot text</div>"`;

exports[`EyebrowText > renders correct HTML structure for each fontSize variant 2`] = `"<div class="eyebrow-text medium">Snapshot text</div>"`;

exports[`EyebrowText > renders correct HTML structure for each fontSize variant 3`] = `"<div class="eyebrow-text small">Snapshot text</div>"`;

exports[`EyebrowText > renders correct HTML structure for each tag variant 1`] = `"<p class="eyebrow-text medium">Snapshot text</p>"`;

exports[`EyebrowText > renders correct HTML structure for each tag variant 2`] = `"<div class="eyebrow-text medium">Snapshot text</div>"`;

exports[`EyebrowText > renders correct HTML structure for each tag variant 3`] = `"<span class="eyebrow-text medium">Snapshot text</span>"`;

exports[`EyebrowText > renders correct HTML structure with all props set 1`] = `"<p class="eyebrow-text custom-class large">New Arrivals</p>"`;

exports[`EyebrowText > renders correct HTML structure with default props 1`] = `"<div class="eyebrow-text medium">Featured Collection</div>"`;
