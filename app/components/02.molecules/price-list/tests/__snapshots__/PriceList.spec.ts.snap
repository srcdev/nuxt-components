// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PriceList > Snapshots > custom headings 1`] = `
"<div class="price-list">
  <div class="price-list__column">
    <h2 class="hero-text price-list__heading subheading axis-horizontal"><span class="text-block-0">Cuts</span></h2>
